# Caddy domain (optional)
# Leave empty for plain HTTP on port 80
# Set to your domain for automatic HTTPS via Let's Encrypt
# DOMAIN=zync.example.com

# Voice services (optional) — start with: docker compose --profile voice up -d
# WHISPER_MODEL=base.en
# WHISPER_COMPUTE_TYPE=int8
# WAKEWORD_MODEL=hey_jarvis
# WAKEWORD_THRESHOLD=0.5

# All other configuration (API keys, integrations, etc.) is managed
# through the Settings UI and stored in the encrypted vault.
