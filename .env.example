# Jira Configuration
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PROJ

# Messages (optional)
MESSAGES_ENDPOINT=

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USERS=123456789

# WhatsApp (Baileys)
WHATSAPP_ENABLED=false
WHATSAPP_AUTH_DIR=./data/whatsapp-auth
WHATSAPP_ALLOWED_NUMBERS=

# Gmail
GMAIL_ENABLED=false
GMAIL_CREDENTIALS_PATH=./data/gmail-credentials.json
GMAIL_TOKEN_PATH=./data/gmail-token.json
GMAIL_POLL_INTERVAL_MS=300000

# Voice (Whisper.cpp)
WHISPER_PATH=whisper-cli
WHISPER_MODEL=./data/ggml-base.en.bin

# OpenCode
OPENCODE_URL=http://localhost:4096

# Proactive Briefings
DEFAULT_CHANNEL=telegram
DEFAULT_CHAT_ID=
MORNING_BRIEFING_CRON=0 8 * * 1-5
EVENING_RECAP_CRON=0 18 * * 1-5

# Server
PORT=3001
